# Server
PORT=3001
HOST=0.0.0.0
OCR_DEFAULT_LANG=eng
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Frontend (SvelteKit) — must point to running Hono server
PUBLIC_API_URL=http://localhost:3001
FRONTEND_PORT=3000

# Optional: full path to bun binary (PM2 needs this if bun isn't in PATH)
# BUN_PATH=/home/user/.bun/bin/bun
